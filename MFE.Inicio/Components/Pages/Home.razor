@page "/"
@using MFE.Inicio.Components.UI
@inject IHttpContextAccessor HttpContext

<PageTitle>Inicio</PageTitle>

<h1 class="text-3xl text-green-600 font-bold">HDI</h1>
<p class="text-gray-400 text-lg">Dashboard</p>

<div class="flex w-full items-start gap-1 flex-col">
    <div class="w-full flex">
        <div class="w-3/12">
            <Card title="Ingresos">
                <Children>
                    <div class="w-full flex items-end gap-2">
                        <span class="text-2xl font-bold text-green-600">120</span>
                        <span class="text-xs">Ingresos nuevos</span>
                    </div>
                </Children>
            </Card>
        </div>

        <div class="w-1/12">
            <Badge Type="success"
                   Content="0938933" />
        </div>
    </div>
    <div class="w-full flex mt-2">
        <Table Title="Listado de Colectividades" Current="mfe-inicio"/>
    </div>
</div>